# =============================================================================
# GATOR - SOVEREIGN ENTITY .gitignore
# CRITICAL: Model files are 14-18GB. They MUST NEVER be committed.
# =============================================================================

# -- MODEL FILES (CRITICAL) ---------------------------------------------------
*.gguf
*.gguf.bak
*.ggml
*.onnx
*.onnx.json
models/donor.gguf
models/tts/
models/voice/
models/_decommissioned/
# models/manifest.json is intentionally tracked (procurement spec, no weights)
# logic_map.gate IS tracked (the Graft, ~2.5 MB) — donor weights NEVER are.

# -- PYTHON RUNTIME -----------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/
env/
*.egg-info/
dist/
*.egg
pip-log.txt

# -- COMPILED NATIVE KERNEL ---------------------------------------------------
*.so
*.a
*.o
*.lo
*.la

# -- CMAKE BUILD ARTIFACTS ----------------------------------------------------
build/
.bootstrap_build/
.bootstrap_cache/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake

# -- ENVIRONMENT & SECRETS ----------------------------------------------------
.env
.env.*
*.pem
*.key
*.crt
secrets/

# -- LANCEDB RUNTIME DATA -----------------------------------------------------
db/
*.lance/

# -- RUNTIME STATE FILES ------------------------------------------------------
bin/*.pid
bin/agentic_cron_state.json
bin/hive_state.json
bin/maintenance_state.json

# -- RUNTIME BINARIES (pre-compiled, not source) ------------------------------
bin/piper
bin/piper_runtime/

# -- SNAPSHOTS & GATOR MAP (generated) ----------------------------------------
bin/gator_map/
bin/hive_nodes/

# -- LOG FILES ----------------------------------------------------------------
logs/
*.log
debug.json

# -- RESEARCH RUNTIME DATA ----------------------------------------------------
research/graphify-out/
research/scholar_sense/hybrid_registry.db
research/scholar_sense/node_registry.json
graphify-out/

# -- PERSONA RUNTIME STATE ----------------------------------------------------
config/persona_traits.json

# -- SQLITE DATABASES ---------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# -- AUDIO ARTIFACTS ----------------------------------------------------------
*.wav

# -- EDITOR / OS NOISE --------------------------------------------------------
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

# -- VENDORED SOURCE (built from upstream, not part of repo) ------------------
vendor/

# -- COMPILED SHARED LIBRARIES (built from vendor/, regenerable) --------------
lib/

# -- COMPILED GATOR-SERVER BINARY (critical runtime, ~9MB, TRACKED for ease) --
# bin/gator-server is intentionally TRACKED despite being a binary
# Rationale: bootstrap complexity >> 9MB storage cost
!bin/gator-server

# launch_gator_server.sh is a shell script (TRACKED)
!bin/launch_gator_server.sh

# -- TEMP / SCRATCH -----------------------------------------------------------
tmp/
*.tmp

# -- LARGE MODEL WEIGHTS (already covered by *.gguf, but double-guard) --------
models/*.gguf
models/*/
!models/__init__.py
!models/datamodel.py
